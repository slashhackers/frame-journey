{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/exec", {
      "prepareCmd": "sed -i 's/VERSION=\".*\"/VERSION=\"${nextRelease.version}\"/' bin/frame-journey && tar -czf frame-journey.tar.gz bin libexec config"
    }],
    ["@semantic-release/git", {
      "assets": ["bin/frame-journey"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [
        {"path": "frame-journey.tar.gz", "label": "Frame Journey Bundle (tar.gz)"}
      ]
    }]
  ]
}
