#!/bin/bash
set -e

# Get the directory where the script is located (resolving symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" &> /dev/null && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$( cd -P "$( dirname "$SOURCE" )" &> /dev/null && pwd )"
PROJECT_ROOT=$(dirname "$BIN_DIR")
LIBEXEC_DIR="$PROJECT_ROOT/libexec"

VERSION="1.4.0"

# Initialize variables
INPUT=""
SELECTED_RESOLUTION=""
TRIM_START=""
DURATION="" # Changed from TRIM_END
SHOW_PROGRESS_ENABLED="false"
DRY_RUN="false"
OUTPUT_FILE_NAME=""
EXPLICIT_AUDIO_INDEX=""
HELP_MODE="false"
COMMAND=""
JSON_OUTPUT="false"
METADATA_TITLE=""
METADATA_DESCRIPTION=""

# Parse arguments
while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -h|--help)
      HELP_MODE="true"
      ;;
    --dry-run)
      DRY_RUN="true"
      ;;
    -v|--version)
      echo "frame-journey v$VERSION"
      exit 0
      ;;
    --json)
      JSON_OUTPUT="true"
      ;;
    --title)
      METADATA_TITLE="$2"
      shift
      ;;
    --description)
      METADATA_DESCRIPTION="$2"
      shift
      ;;
    info)
      COMMAND="info"
      ;;
    --update)
      echo "🔍 Checking for updates on GitHub..."
      LATEST_TAG=$(curl -s https://api.github.com/repos/slashhackers/frame-journey/releases/latest | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/' || echo "")
      
      if [ -z "$LATEST_TAG" ]; then
        echo "⚠️  Could not fetch version info from GitHub. Trying forced update..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/slashhackers/frame-journey/main/install.sh)"
        exit 0
      fi

      # Remove 'v' prefix for comparison if present
      LATEST_VERSION=${LATEST_TAG#v}
      
      if [ "$LATEST_VERSION" == "$VERSION" ]; then
        echo "✅ You are already using the latest version (v$VERSION)."
      else
        echo "✨ New version available: $LATEST_TAG (Current: v$VERSION)"
        echo "🚀 Running installer..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/slashhackers/frame-journey/main/install.sh)"
      fi
      exit 0
      ;;
    -r)
      SELECTED_RESOLUTION="$2"
      shift
      ;;
    --trim-start)
      TRIM_START="$2"
      shift
      ;;
    --duration) # Changed from --trim-end
      DURATION="$2"
      shift
      ;;
    --show-progress)
      SHOW_PROGRESS_ENABLED="true"
      ;;
    -o|--output)
      OUTPUT_FILE_NAME="$2"
      shift
      ;;
    --audio)
      EXPLICIT_AUDIO_INDEX="$2"
      shift
      ;;
    -*)
      echo "Invalid option: $1" >&2
      exit 1
      ;;
    *)
      INPUT="$1"
      ;;
  esac
  shift
done

if [ "$HELP_MODE" = "true" ] || ([ -z "$INPUT" ] && [ -z "$COMMAND" ]); then
    echo "Usage: frame-journey [options] <input_video_file>"
    echo "       frame-journey info [options] <input_video_file>"
    echo ""
    echo "Options:"
    echo "  -r <1080|720|480|360> Select output resolution"
    echo "  --trim-start <time>   Start time (e.g. 00:00:10)"
    echo "  --duration <sec>      Duration in seconds"
    echo "  --title <text>        Set media title (default: filename)"
    echo "  --description <text>  Set media description (default: empty)"
    echo "  --show-progress       Show live progress bar"
    echo "  --dry-run             Show command without encoding"
    echo "  --json                Output info in JSON format"
    echo "  -v, --version         Show version"
    echo "  --update              Check for updates"
    
    if [ "$HELP_MODE" = "true" ]; then
        exit 0
    else
        exit 1
    fi
fi

if [ "$COMMAND" = "info" ]; then
    FORMAT="text"
    if [ "$JSON_OUTPUT" = "true" ]; then
        FORMAT="json"
    fi
    bash "$LIBEXEC_DIR/utils/video_info.sh" "$INPUT" "$FORMAT"
    exit 0
fi

# Default title to filename if not provided
if [ -z "$METADATA_TITLE" ]; then
    METADATA_TITLE=$(basename "$INPUT")
    # Remove extension
    METADATA_TITLE="${METADATA_TITLE%.*}"
fi

IFS="|" read HEIGHT DURATION_UNUSED AUDIO_STREAMS <<< "$(bash "$LIBEXEC_DIR/utils/ffprobe.sh" "$INPUT")"
if [ "$SHOW_PROGRESS_ENABLED" = "true" ]; then
  echo "🔍 Analyzing video file..."
fi
AUDIO_STREAMS_ARRAY=($AUDIO_STREAMS)
if [ "$SHOW_PROGRESS_ENABLED" = "true" ]; then
  echo "🎧 Selecting audio track..."
fi

if [ -n "$SELECTED_RESOLUTION" ]; then
    # Validate selected resolution
    if [ "$SELECTED_RESOLUTION" != "720" ] && [ "$SELECTED_RESOLUTION" != "1080" ] && [ "$SELECTED_RESOLUTION" != "480" ] && [ "$SELECTED_RESOLUTION" != "360" ]; then
        echo "Error: Invalid resolution specified. Use '1080', '720', '480' or '360'."
        exit 1
    fi
    RESOLUTIONS="$SELECTED_RESOLUTION"
else
    RESOLUTIONS=$(bash "$LIBEXEC_DIR/video/select_resolution.sh" "$HEIGHT")
fi


AUDIO_INDEX=$(bash "$LIBEXEC_DIR/audio/select_audio.sh" "$INPUT" "${AUDIO_STREAMS_ARRAY[*]}" "$EXPLICIT_AUDIO_INDEX")

# Calculate EFFECTIVE_DURATION for progress monitoring
EFFECTIVE_DURATION=""
if [ -n "$DURATION" ]; then
  # If --duration is specified, use that as the effective duration
  EFFECTIVE_DURATION="$DURATION"
else
  # Otherwise, use the full video duration
  EFFECTIVE_DURATION="$DURATION_UNUSED"
fi

if [ "$SHOW_PROGRESS_ENABLED" = "true" ]; then
  echo "🎬 Starting video encoding..."
fi

for RES in $RESOLUTIONS; do
  TRIM_ARGS=""
  if [ -n "$TRIM_START" ]; then
    TRIM_ARGS+="--trim-start \"$TRIM_START\" "
  fi
  if [ -n "$DURATION" ]; then # Changed from TRIM_END
    TRIM_ARGS+="--duration \"$DURATION\" " # Added space
  fi

  METADATA_ARGS="--title \"$METADATA_TITLE\" --description \"$METADATA_DESCRIPTION\""

  PROGRESS_ARGS=""
  if [ "$SHOW_PROGRESS_ENABLED" = "true" ]; then
    PROGRESS_ARGS+="--progress-duration \"$EFFECTIVE_DURATION\""
  fi

  CURRENT_OUTPUT_FILE=""
  if [ -n "$OUTPUT_FILE_NAME" ]; then
    CURRENT_OUTPUT_FILE="$OUTPUT_FILE_NAME"
  else
    CURRENT_OUTPUT_FILE="output_${RES}p.mp4"
  fi

  [ "$RES" = "1080" ] && CMD="bash \"$LIBEXEC_DIR/video/transcode_1080p.sh\" \"$INPUT\" \"$AUDIO_INDEX\" \"$CURRENT_OUTPUT_FILE\" $TRIM_ARGS $METADATA_ARGS $PROGRESS_ARGS"
  [ "$RES" = "720" ] && CMD="bash \"$LIBEXEC_DIR/video/transcode_720p.sh\" \"$INPUT\" \"$AUDIO_INDEX\" \"$CURRENT_OUTPUT_FILE\" $TRIM_ARGS $METADATA_ARGS $PROGRESS_ARGS"
  [ "$RES" = "480" ] && CMD="bash \"$LIBEXEC_DIR/video/transcode_480p.sh\" \"$INPUT\" \"$AUDIO_INDEX\" \"$CURRENT_OUTPUT_FILE\" $TRIM_ARGS $METADATA_ARGS $PROGRESS_ARGS"
  [ "$RES" = "360" ] && CMD="bash \"$LIBEXEC_DIR/video/transcode_360p.sh\" \"$INPUT\" \"$AUDIO_INDEX\" \"$CURRENT_OUTPUT_FILE\" $TRIM_ARGS $METADATA_ARGS $PROGRESS_ARGS"

  if [ "$DRY_RUN" = "true" ]; then
    echo "🌵 [DRY RUN] Would execute: $CMD"
  else
    eval "$CMD"
  fi
done
echo "✅ Encoding completed"
